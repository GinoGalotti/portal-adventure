{
  "name": "portal-field-ops-game",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n app,api -c cyan,yellow \"vite\" \"wrangler dev --port 8787\"",
    "dev:app": "vite",
    "dev:api": "wrangler dev --port 8787",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "vitest run && playwright test",
    "simulate": "tsx simulation/cli.ts --count 1000 --strategies all",
    "simulate:quick": "tsx simulation/cli.ts --count 100 --strategies all",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "i18next": "^23.16.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@playwright/test": "^1.48.2",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "wrangler": "^3.91.0"
  }
}
